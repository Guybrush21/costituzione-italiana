---
/**
 * Table of Contents component
 * Displays the structure of the Italian Constitution with collapsible sections
 */

import { costituzioneStructure } from "../data/structure";

interface Props {
  currentArticle?: number | string;
  currentType?: "articolo" | "disposizione";
}

const { currentArticle, currentType } = Astro.props;

const { principiFondamentali, parti, disposizioniTransitorie } =
  costituzioneStructure;

function isCurrentArticle(
  numero: number | string,
  tipo: "articolo" | "disposizione",
): boolean {
  return currentArticle === numero && currentType === tipo;
}
---

<nav
  class="hidden lg:block sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto p-4 bg-gray-50 dark:bg-gray-800/50 rounded-xl text-sm"
  aria-label="Indice della Costituzione"
>
  <!-- Principi Fondamentali -->
  <details class="mb-4 group" open>
    <summary
      class="flex items-center p-2 font-semibold text-gray-900 dark:text-gray-100 cursor-pointer list-none rounded hover:bg-gray-200 dark:hover:bg-gray-700"
    >
      <span
        class="mr-2 text-xs text-gray-400 transition-transform group-open:rotate-90"
        >▶</span
      >
      <a
        href="/principi-fondamentali"
        class="text-inherit no-underline hover:text-primary"
        >{principiFondamentali.nome}</a
      >
    </summary>
    <ul class="list-none p-0 mt-2 ml-4">
      {
        principiFondamentali.articoli.map((num) => (
          <li class="mb-1">
            <a
              href={`/articolo/${num}`}
              class:list={[
                "block px-2 py-1 rounded text-gray-500 dark:text-gray-400 no-underline transition-colors hover:text-primary hover:bg-primary-bg dark:hover:bg-primary/20",
                {
                  "text-primary bg-primary-bg dark:bg-primary/20 font-medium":
                    isCurrentArticle(num, "articolo"),
                },
              ]}
            >
              Art. {num}
            </a>
          </li>
        ))
      }
    </ul>
  </details>

  <!-- Parte I -->
  <details class="mb-4 group" open>
    <summary
      class="flex items-center p-2 font-semibold text-gray-900 dark:text-gray-100 cursor-pointer list-none rounded hover:bg-gray-200 dark:hover:bg-gray-700"
    >
      <span
        class="mr-2 text-xs text-gray-400 transition-transform group-open:rotate-90"
        >▶</span
      >
      <a href="/parte/1" class="text-inherit no-underline hover:text-primary"
        >Parte I</a
      >
    </summary>
    <div class="pl-4 mt-2">
      {
        parti[0].titoli.map((titolo) => (
          <details class="mb-2 group/sub">
            <summary class="flex items-center px-2 py-1 font-medium text-gray-600 dark:text-gray-400 cursor-pointer list-none rounded hover:bg-gray-200 dark:hover:bg-gray-700">
              <span class="mr-2 text-[0.6em] text-gray-400 transition-transform group-open/sub:rotate-90">
                ▶
              </span>
              Titolo {titolo.numero} - {titolo.nome}
            </summary>
            <ul class="list-none p-0 mt-2 ml-4">
              {titolo.articoli.map((num) => (
                <li class="mb-1">
                  <a
                    href={`/articolo/${num}`}
                    class:list={[
                      "block px-2 py-1 rounded text-gray-500 dark:text-gray-400 no-underline transition-colors hover:text-primary hover:bg-primary-bg dark:hover:bg-primary/20",
                      {
                        "text-primary bg-primary-bg dark:bg-primary/20 font-medium":
                          isCurrentArticle(num, "articolo"),
                      },
                    ]}
                  >
                    Art. {num}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        ))
      }
    </div>
  </details>

  <!-- Parte II -->
  <details class="mb-4 group">
    <summary
      class="flex items-center p-2 font-semibold text-gray-900 dark:text-gray-100 cursor-pointer list-none rounded hover:bg-gray-200 dark:hover:bg-gray-700"
    >
      <span
        class="mr-2 text-xs text-gray-400 transition-transform group-open:rotate-90"
        >▶</span
      >
      <a href="/parte/2" class="text-inherit no-underline hover:text-primary"
        >Parte II</a
      >
    </summary>
    <div class="pl-4 mt-2">
      {
        parti[1].titoli.map((titolo) => (
          <details class="mb-2 group/sub">
            <summary class="flex items-center px-2 py-1 font-medium text-gray-600 dark:text-gray-400 cursor-pointer list-none rounded hover:bg-gray-200 dark:hover:bg-gray-700">
              <span class="mr-2 text-[0.6em] text-gray-400 transition-transform group-open/sub:rotate-90">
                ▶
              </span>
              Titolo {titolo.numero} - {titolo.nome}
            </summary>
            {titolo.sezioni ? (
              <div class="pl-4 mt-2">
                {titolo.sezioni.map((sezione) => (
                  <details class="mb-2 group/subsub">
                    <summary class="flex items-center px-2 py-1 text-xs text-gray-500 dark:text-gray-400 cursor-pointer list-none rounded hover:bg-gray-200 dark:hover:bg-gray-700">
                      <span class="mr-2 text-[0.6em] text-gray-400 transition-transform group-open/subsub:rotate-90">
                        ▶
                      </span>
                      {sezione.nome}
                    </summary>
                    <ul class="list-none p-0 mt-2 ml-4">
                      {sezione.articoli.map((num) => (
                        <li class="mb-1">
                          <a
                            href={`/articolo/${num}`}
                            class:list={[
                              "block px-2 py-1 rounded text-gray-500 dark:text-gray-400 no-underline transition-colors hover:text-primary hover:bg-primary-bg dark:hover:bg-primary/20",
                              {
                                "text-primary bg-primary-bg dark:bg-primary/20 font-medium":
                                  isCurrentArticle(num, "articolo"),
                              },
                            ]}
                          >
                            Art. {num}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </details>
                ))}
              </div>
            ) : (
              <ul class="list-none p-0 mt-2 ml-4">
                {titolo.articoli.map((num) => (
                  <li class="mb-1">
                    <a
                      href={`/articolo/${num}`}
                      class:list={[
                        "block px-2 py-1 rounded text-gray-500 dark:text-gray-400 no-underline transition-colors hover:text-primary hover:bg-primary-bg dark:hover:bg-primary/20",
                        {
                          "text-primary bg-primary-bg dark:bg-primary/20 font-medium":
                            isCurrentArticle(num, "articolo"),
                        },
                      ]}
                    >
                      Art. {num}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </details>
        ))
      }
    </div>
  </details>

  <!-- Disposizioni Transitorie -->
  <details class="mb-4 group">
    <summary
      class="flex items-center p-2 font-semibold text-gray-900 dark:text-gray-100 cursor-pointer list-none rounded hover:bg-gray-200 dark:hover:bg-gray-700"
    >
      <span
        class="mr-2 text-xs text-gray-400 transition-transform group-open:rotate-90"
        >▶</span
      >
      <a
        href="/disposizioni-transitorie"
        class="text-inherit no-underline hover:text-primary">Disposizioni</a
      >
    </summary>
    <ul class="list-none p-0 mt-2 ml-4">
      {
        disposizioniTransitorie.disposizioni.map((num) => (
          <li class="mb-1">
            <a
              href={`/disposizione/${num.toLowerCase()}`}
              class:list={[
                "block px-2 py-1 rounded text-gray-500 dark:text-gray-400 no-underline transition-colors hover:text-primary hover:bg-primary-bg dark:hover:bg-primary/20",
                {
                  "text-primary bg-primary-bg dark:bg-primary/20 font-medium":
                    isCurrentArticle(num, "disposizione"),
                },
              ]}
            >
              {num}
            </a>
          </li>
        ))
      }
    </ul>
  </details>
</nav>

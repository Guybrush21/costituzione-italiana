---
/**
 * Table of Contents component
 * Displays the structure of the Italian Constitution with collapsible sections
 */

import { costituzioneStructure } from '../data/structure';

interface Props {
  currentArticle?: number | string;
  currentType?: 'articolo' | 'disposizione';
}

const { currentArticle, currentType } = Astro.props;

const { principiFondamentali, parti, disposizioniTransitorie } = costituzioneStructure;

function isCurrentArticle(numero: number | string, tipo: 'articolo' | 'disposizione'): boolean {
  return currentArticle === numero && currentType === tipo;
}
---

<nav class="toc" aria-label="Indice della Costituzione">
  <!-- Principî Fondamentali -->
  <details class="toc-section" open>
    <summary class="toc-section-title">
      <a href="/principi-fondamentali">{principiFondamentali.nome}</a>
    </summary>
    <ul class="toc-list">
      {principiFondamentali.articoli.map((num) => (
        <li class="toc-item">
          <a 
            href={`/articolo/${num}`} 
            class:list={['toc-link', { active: isCurrentArticle(num, 'articolo') }]}
          >
            Art. {num}
          </a>
        </li>
      ))}
    </ul>
  </details>

  <!-- Parte I -->
  <details class="toc-section" open>
    <summary class="toc-section-title">
      <a href="/parte/1">Parte I</a>
    </summary>
    <div class="toc-nested">
      {parti[0].titoli.map((titolo) => (
        <details class="toc-subsection">
          <summary class="toc-subsection-title">
            Titolo {titolo.numero} - {titolo.nome}
          </summary>
          <ul class="toc-list">
            {titolo.articoli.map((num) => (
              <li class="toc-item">
                <a 
                  href={`/articolo/${num}`} 
                  class:list={['toc-link', { active: isCurrentArticle(num, 'articolo') }]}
                >
                  Art. {num}
                </a>
              </li>
            ))}
          </ul>
        </details>
      ))}
    </div>
  </details>

  <!-- Parte II -->
  <details class="toc-section">
    <summary class="toc-section-title">
      <a href="/parte/2">Parte II</a>
    </summary>
    <div class="toc-nested">
      {parti[1].titoli.map((titolo) => (
        <details class="toc-subsection">
          <summary class="toc-subsection-title">
            Titolo {titolo.numero} - {titolo.nome}
          </summary>
          {titolo.sezioni ? (
            <div class="toc-nested">
              {titolo.sezioni.map((sezione) => (
                <details class="toc-subsubsection">
                  <summary class="toc-subsubsection-title">
                    {sezione.nome}
                  </summary>
                  <ul class="toc-list">
                    {sezione.articoli.map((num) => (
                      <li class="toc-item">
                        <a 
                          href={`/articolo/${num}`} 
                          class:list={['toc-link', { active: isCurrentArticle(num, 'articolo') }]}
                        >
                          Art. {num}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              ))}
            </div>
          ) : (
            <ul class="toc-list">
              {titolo.articoli.map((num) => (
                <li class="toc-item">
                  <a 
                    href={`/articolo/${num}`} 
                    class:list={['toc-link', { active: isCurrentArticle(num, 'articolo') }]}
                  >
                    Art. {num}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </details>
      ))}
    </div>
  </details>

  <!-- Disposizioni Transitorie -->
  <details class="toc-section">
    <summary class="toc-section-title">
      <a href="/disposizioni-transitorie">Disposizioni</a>
    </summary>
    <ul class="toc-list">
      {disposizioniTransitorie.disposizioni.map((num) => (
        <li class="toc-item">
          <a 
            href={`/disposizione/${num.toLowerCase()}`} 
            class:list={['toc-link', { active: isCurrentArticle(num, 'disposizione') }]}
          >
            {num}
          </a>
        </li>
      ))}
    </ul>
  </details>
</nav>

<style>
  .toc {
    position: sticky;
    top: calc(var(--header-height) + var(--space-4));
    max-height: calc(100vh - var(--header-height) - var(--space-8));
    overflow-y: auto;
    padding: var(--space-4);
    background-color: var(--color-bg-secondary);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
  }

  .toc-section {
    margin-bottom: var(--space-4);
  }

  .toc-section-title {
    display: flex;
    align-items: center;
    font-weight: 600;
    color: var(--color-text-primary);
    cursor: pointer;
    list-style: none;
    padding: var(--space-2);
    border-radius: var(--radius-sm);
  }

  .toc-section-title:hover {
    background-color: var(--color-bg-tertiary);
  }

  .toc-section-title::marker,
  .toc-section-title::-webkit-details-marker {
    display: none;
  }

  .toc-section-title::before {
    content: '▶';
    display: inline-block;
    margin-right: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    transition: transform var(--transition-fast);
  }

  details[open] > .toc-section-title::before {
    transform: rotate(90deg);
  }

  .toc-section-title a {
    color: inherit;
    text-decoration: none;
  }

  .toc-section-title a:hover {
    color: var(--color-primary);
  }

  .toc-nested {
    padding-left: var(--space-4);
    margin-top: var(--space-2);
  }

  .toc-subsection,
  .toc-subsubsection {
    margin-bottom: var(--space-2);
  }

  .toc-subsection-title,
  .toc-subsubsection-title {
    display: flex;
    align-items: center;
    padding: var(--space-1) var(--space-2);
    font-weight: 500;
    color: var(--color-text-secondary);
    cursor: pointer;
    list-style: none;
    border-radius: var(--radius-sm);
  }

  .toc-subsection-title:hover,
  .toc-subsubsection-title:hover {
    background-color: var(--color-bg-tertiary);
  }

  .toc-subsection-title::marker,
  .toc-subsection-title::-webkit-details-marker,
  .toc-subsubsection-title::marker,
  .toc-subsubsection-title::-webkit-details-marker {
    display: none;
  }

  .toc-subsection-title::before,
  .toc-subsubsection-title::before {
    content: '▶';
    display: inline-block;
    margin-right: var(--space-2);
    font-size: 0.6em;
    color: var(--color-text-muted);
    transition: transform var(--transition-fast);
  }

  details[open] > .toc-subsection-title::before,
  details[open] > .toc-subsubsection-title::before {
    transform: rotate(90deg);
  }

  .toc-subsubsection-title {
    font-size: var(--text-xs);
    font-weight: 400;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0 0 var(--space-4);
  }

  .toc-item {
    margin-bottom: var(--space-1);
  }

  .toc-link {
    display: block;
    padding: var(--space-1) var(--space-2);
    color: var(--color-text-muted);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .toc-link:hover {
    color: var(--color-primary);
    background-color: var(--color-primary-bg);
  }

  .toc-link.active {
    color: var(--color-primary);
    background-color: var(--color-primary-bg);
    font-weight: 500;
  }

  @media (max-width: 1024px) {
    .toc {
      display: none;
    }
  }
</style>

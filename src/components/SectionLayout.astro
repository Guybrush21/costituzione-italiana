---
/**
 * SectionLayout Component
 *
 * Shared layout for section pages (Principi Fondamentali, Parti, Disposizioni).
 * Provides consistent header, breadcrumbs, and grid layout.
 */
import Layout from "./Layout.astro";
import { Container, Breadcrumbs, PageTitle, Text } from "./ui";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description: string;
  metaDescription: string;
  breadcrumbs: BreadcrumbItem[];
}

const { title, description, metaDescription, breadcrumbs } = Astro.props;
---

<Layout title={title} description={metaDescription}>
  <main class="py-8">
    <Container>
      <header class="max-w-3xl mx-auto mb-10 text-center">
        <div class="mb-4">
          <Breadcrumbs items={breadcrumbs} centered />
        </div>
        <PageTitle>{title}</PageTitle>
        <Text muted size="lg" class="max-w-xl mx-auto">
          {description}
        </Text>
      </header>

      <div class="grid gap-4 max-w-3xl mx-auto">
        <slot />
      </div>
    </Container>
  </main>
</Layout>

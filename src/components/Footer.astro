---
// Footer component
const currentYear = new Date().getFullYear();
---

<footer class="mt-16 py-8 bg-gray-50 border-t border-gray-200 [data-theme='dark']:bg-gray-900 [data-theme='dark']:border-gray-800">
  <div class="max-w-6xl mx-auto px-4 text-center text-sm text-gray-500 [data-theme='dark']:text-gray-400">
    <p>
      Costituzione della Repubblica Italiana
      <br>
      Promulgata il 27 dicembre 1947 · Entrata in vigore il 1° gennaio 1948
    </p>
    <p class="mt-4">
      <a href="/testo-completo" class="text-gray-600 hover:text-primary [data-theme='dark']:text-gray-300">Testo completo</a>
      <span class="mx-2">·</span>
      <a href="https://www.gazzettaufficiale.it/dettaglio/codici/costituzione" target="_blank" rel="noopener" class="text-gray-600 hover:text-primary [data-theme='dark']:text-gray-300">Gazzetta Ufficiale</a>
      <span class="mx-2">·</span>
      <a href="https://github.com/LBreda/costituzione" target="_blank" rel="noopener" class="text-gray-600 hover:text-primary [data-theme='dark']:text-gray-300">Sorgente</a>
    </p>
    <p class="mt-4 text-xs">
      © {currentYear} · Progetto open source
    </p>
  </div>
</footer>

---
/**
 * LinkButton Component
 *
 * A styled link that looks like a button, used for navigation CTAs.
 *
 * @example
 * <LinkButton href="/articolo/1">
 *   <Icon slot="icon" />
 *   Vai all'Art. 1
 * </LinkButton>
 */

interface Props {
  /** Link destination */
  href: string;
  /** Additional CSS classes */
  class?: string;
}

const { href, class: className } = Astro.props;
---

<a
  href={href}
  class:list={[
    "flex items-center gap-2 px-6 py-3",
    "bg-gray-100 dark:bg-gray-800",
    "border border-gray-200 dark:border-gray-700",
    "rounded-lg font-medium",
    "text-gray-900 dark:text-gray-100",
    "transition-colors",
    "hover:bg-primary-bg dark:hover:bg-primary/20 hover:border-primary hover:text-primary",
    "no-underline",
    className,
  ]}
>
  <slot />
</a>

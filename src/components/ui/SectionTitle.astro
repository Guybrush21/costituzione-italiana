---
/**
 * SectionTitle Component
 * 
 * Section heading with consistent serif styling and optional border.
 * Used for major section headers throughout the site.
 * 
 * @example
 * <SectionTitle>Principi Fondamentali</SectionTitle>
 * <SectionTitle id="parte-1" centered>Parte I</SectionTitle>
 * <SectionTitle level={3}>Titolo I - Rapporti Civili</SectionTitle>
 */

interface Props {
  /** HTML id attribute */
  id?: string;
  /** Heading level: 2, 3, or 4 */
  level?: 2 | 3 | 4;
  /** Center the text */
  centered?: boolean;
  /** Show bottom border */
  border?: boolean;
  /** Additional CSS classes */
  class?: string;
}

const { 
  id, 
  level = 2, 
  centered = false, 
  border = true,
  class: className 
} = Astro.props;

const Tag = `h${level}` as 'h2' | 'h3' | 'h4';

const sizeClasses = {
  2: 'text-3xl mb-8 pb-4',
  3: 'text-2xl mb-6 pb-2',
  4: 'text-lg mb-4',
};

const baseClasses = [
  'font-serif text-primary',
  sizeClasses[level],
  centered && 'text-center',
  border && 'border-b border-gray-300 dark:border-gray-700',
  className,
].filter(Boolean).join(' ');
---

<Tag id={id} class={baseClasses}>
  <slot />
</Tag>

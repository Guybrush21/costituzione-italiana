---
// Header component with navigation and search
---

<header class="sticky top-0 z-50 h-16 bg-white/95 backdrop-blur border-b border-gray-200">
  <div class="flex items-center justify-between h-full max-w-6xl mx-auto px-4">
    <a href="/" class="flex items-center gap-3 font-serif text-lg font-semibold text-gray-900 hover:text-primary no-underline">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M12 2L2 7V10H22V7L12 2Z" fill="currentColor" opacity="0.2"/>
        <path d="M4 10V19H8V14H16V19H20V10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M2 19H22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="M12 2L2 7H22L12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>Costituzione Italiana</span>
    </a>
    
    <nav class="hidden md:flex items-center gap-6">
      <a href="/principi-fondamentali" class="text-sm font-medium text-gray-600 hover:text-primary no-underline">Principi Fondamentali</a>
      <a href="/parte/1" class="text-sm font-medium text-gray-600 hover:text-primary no-underline">Parte I</a>
      <a href="/parte/2" class="text-sm font-medium text-gray-600 hover:text-primary no-underline">Parte II</a>
      <a href="/disposizioni-transitorie" class="text-sm font-medium text-gray-600 hover:text-primary no-underline">Disposizioni</a>
    </nav>
    
    <div class="flex items-center gap-4">
      <button 
        type="button" 
        class="flex items-center gap-2 px-3 py-2 bg-gray-100 border border-gray-200 rounded-lg text-gray-500 text-sm cursor-pointer transition-colors hover:border-gray-300 hover:bg-gray-200"
        id="search-trigger"
        aria-label="Cerca nella Costituzione"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <span class="hidden sm:inline">Cerca...</span>
        <kbd class="hidden sm:inline font-mono text-xs px-1.5 py-0.5 bg-gray-200 rounded">⌘K</kbd>
      </button>
      
      <!-- Mobile menu button -->
      <button 
        type="button" 
        class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100"
        id="mobile-menu-toggle"
        aria-label="Menu"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 12h18M3 6h18M3 18h18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  // Search trigger - keyboard shortcut
  const searchTrigger = document.getElementById('search-trigger');
  
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      searchTrigger?.click();
    }
  });
</script>

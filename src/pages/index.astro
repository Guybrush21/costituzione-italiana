---
import Layout from '../components/Layout.astro';
import { costituzioneStructure } from '../data/structure';

const { principiFondamentali, parti, disposizioniTransitorie } = costituzioneStructure;
---

<Layout>
  <main class="py-8">
    <div class="max-w-6xl mx-auto px-4">
      <!-- Hero Section -->
      <header class="text-center py-12 border-b border-gray-200 mb-12 [data-theme='dark']:border-gray-800">
        <h1 class="text-4xl md:text-5xl font-serif font-semibold text-primary mb-4">
          Costituzione della Repubblica Italiana
        </h1>
        <p class="text-lg text-gray-600 mb-8 [data-theme='dark']:text-gray-400">
          Promulgata il 27 dicembre 1947<br>
          Entrata in vigore il 1° gennaio 1948
        </p>
        <div class="flex justify-center gap-12">
          <div class="flex flex-col items-center">
            <span class="font-serif text-3xl font-bold text-primary">139</span>
            <span class="text-sm text-gray-500">Articoli</span>
          </div>
          <div class="flex flex-col items-center">
            <span class="font-serif text-3xl font-bold text-primary">XVIII</span>
            <span class="text-sm text-gray-500">Disposizioni Transitorie</span>
          </div>
        </div>
      </header>

      <!-- Quick Navigation -->
      <nav class="flex justify-center gap-4 mb-12 flex-wrap">
        <a href="/articolo/1" class="flex items-center gap-2 px-6 py-3 bg-gray-100 border border-gray-200 rounded-lg font-medium text-gray-900 transition-colors hover:bg-primary-bg hover:border-primary hover:text-primary no-underline [data-theme='dark']:bg-gray-800 [data-theme='dark']:border-gray-700 [data-theme='dark']:text-gray-100">
          <span class="flex items-center justify-center w-6 h-6 bg-primary text-white text-xs font-bold rounded">1</span>
          <span>Vai all'Art. 1</span>
        </a>
        <a href="/testo-completo" class="flex items-center gap-2 px-6 py-3 bg-gray-100 border border-gray-200 rounded-lg font-medium text-gray-900 transition-colors hover:bg-primary-bg hover:border-primary hover:text-primary no-underline [data-theme='dark']:bg-gray-800 [data-theme='dark']:border-gray-700 [data-theme='dark']:text-gray-100">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14,2 14,8 20,8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
          <span>Testo completo</span>
        </a>
      </nav>

      <!-- Structure Overview -->
      <section class="grid gap-10 mb-12">
        <!-- Principî Fondamentali -->
        <div class="p-6 bg-gray-50 rounded-xl [data-theme='dark']:bg-gray-900">
          <h2 class="mb-2 font-serif text-2xl">
            <a href="/principi-fondamentali" class="text-gray-900 no-underline hover:text-primary [data-theme='dark']:text-gray-100">{principiFondamentali.nome}</a>
          </h2>
          <p class="text-sm text-gray-500 mb-4">Articoli 1 - 12</p>
          <div class="flex flex-wrap gap-2">
            {principiFondamentali.articoli.map((num) => (
              <a href={`/articolo/${num}`} class="px-3 py-2 bg-white border border-gray-200 rounded text-sm text-gray-600 no-underline transition-colors hover:border-primary hover:text-primary [data-theme='dark']:bg-gray-800 [data-theme='dark']:border-gray-700 [data-theme='dark']:text-gray-300">
                Art. {num}
              </a>
            ))}
          </div>
        </div>

        <!-- Parte I -->
        <div class="p-6 bg-gray-50 rounded-xl [data-theme='dark']:bg-gray-900">
          <h2 class="mb-2 font-serif text-2xl">
            <a href="/parte/1" class="text-gray-900 no-underline hover:text-primary [data-theme='dark']:text-gray-100">Parte I - {parti[0].nome}</a>
          </h2>
          <p class="text-sm text-gray-500 mb-4">Articoli 13 - 54</p>
          <div class="grid gap-4">
            {parti[0].titoli.map((titolo) => (
              <div class="p-4 bg-white rounded-lg [data-theme='dark']:bg-gray-800">
                <h3 class="text-base font-semibold mb-1">Titolo {titolo.numero} - {titolo.nome}</h3>
                <p class="text-sm text-gray-500 m-0">
                  Art. {titolo.articoli[0]} - {titolo.articoli[titolo.articoli.length - 1]}
                </p>
              </div>
            ))}
          </div>
        </div>

        <!-- Parte II -->
        <div class="p-6 bg-gray-50 rounded-xl [data-theme='dark']:bg-gray-900">
          <h2 class="mb-2 font-serif text-2xl">
            <a href="/parte/2" class="text-gray-900 no-underline hover:text-primary [data-theme='dark']:text-gray-100">Parte II - {parti[1].nome}</a>
          </h2>
          <p class="text-sm text-gray-500 mb-4">Articoli 55 - 139</p>
          <div class="grid gap-4">
            {parti[1].titoli.map((titolo) => (
              <div class="p-4 bg-white rounded-lg [data-theme='dark']:bg-gray-800">
                <h3 class="text-base font-semibold mb-1">Titolo {titolo.numero} - {titolo.nome}</h3>
                <p class="text-sm text-gray-500 m-0">
                  Art. {titolo.articoli[0]} - {titolo.articoli[titolo.articoli.length - 1]}
                </p>
              </div>
            ))}
          </div>
        </div>

        <!-- Disposizioni Transitorie -->
        <div class="p-6 bg-gray-50 rounded-xl [data-theme='dark']:bg-gray-900">
          <h2 class="mb-2 font-serif text-2xl">
            <a href="/disposizioni-transitorie" class="text-gray-900 no-underline hover:text-primary [data-theme='dark']:text-gray-100">{disposizioniTransitorie.nome}</a>
          </h2>
          <p class="text-sm text-gray-500 mb-4">Disposizioni I - XVIII</p>
          <div class="flex flex-wrap gap-2">
            {disposizioniTransitorie.disposizioni.map((num) => (
              <a href={`/disposizione/${num.toLowerCase()}`} class="px-3 py-2 bg-white border border-gray-200 rounded text-sm text-gray-600 no-underline transition-colors hover:border-primary hover:text-primary [data-theme='dark']:bg-gray-800 [data-theme='dark']:border-gray-700 [data-theme='dark']:text-gray-300">
                {num}
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- Preamble -->
      <section class="max-w-3xl mx-auto pt-8 border-t border-gray-200 [data-theme='dark']:border-gray-800">
        <h2 class="text-center font-serif text-2xl mb-6">Preambolo</h2>
        <blockquote class="m-0 p-6 bg-gray-50 rounded-lg border-l-4 border-primary font-serif text-lg leading-relaxed text-gray-600 [data-theme='dark']:bg-gray-900 [data-theme='dark']:text-gray-400">
          <p class="mb-4"><strong>IL CAPO PROVVISORIO DELLO STATO</strong></p>
          <p class="mb-4">
            Vista la deliberazione dell'Assemblea Costituente, che nella seduta 
            del 22 dicembre 1947 ha approvato la Costituzione della Repubblica Italiana;
          </p>
          <p class="mb-4">Vista la XVIII disposizione finale della Costituzione;</p>
          <p class="mb-4"><strong>PROMULGA</strong></p>
          <p class="m-0">la Costituzione della Repubblica Italiana nel seguente testo:</p>
        </blockquote>
      </section>
    </div>
  </main>
</Layout>

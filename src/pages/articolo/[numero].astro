---
import { getCollection, render } from 'astro:content';
import Layout from '../../components/Layout.astro';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const articoli = await getCollection('articoli', ({ data }) => data.tipo === 'articolo');
  
  return articoli.map((articolo) => ({
    params: { numero: String(articolo.data.numero) },
    props: { articolo },
  }));
}

const { articolo } = Astro.props;
const { Content } = await render(articolo);

const { numero, titolo, abrogato, parte, titolo_sezione, sezione, descrizione } = articolo.data;
---

<Layout 
  title={titolo} 
  description={descrizione}
>
  <ArticleLayout
    numero={numero}
    tipo="articolo"
    titolo={titolo}
    abrogato={abrogato}
    parte={parte}
    titoloSezione={titolo_sezione}
    sezione={sezione}
  >
    <Content />
  </ArticleLayout>
</Layout>

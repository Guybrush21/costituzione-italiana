---
import { getCollection, render } from 'astro:content';
import Layout from '../components/Layout.astro';
import { costituzioneStructure } from '../data/structure';

// Get all articles and dispositions
const allArticoli = await getCollection('articoli');

// Separate and sort
const articoli = allArticoli
  .filter(a => a.data.tipo === 'articolo')
  .sort((a, b) => (a.data.numero as number) - (b.data.numero as number));

const romanOrder = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X', 'XI', 'XII', 'XIII', 'XIV', 'XV', 'XVI', 'XVII', 'XVIII'];
const disposizioni = allArticoli
  .filter(a => a.data.tipo === 'disposizione')
  .sort((a, b) => romanOrder.indexOf(a.data.numero as string) - romanOrder.indexOf(b.data.numero as string));

// Pre-render all content
const renderedArticoli = await Promise.all(
  articoli.map(async (a) => ({
    ...a,
    rendered: await render(a),
  }))
);

const renderedDisposizioni = await Promise.all(
  disposizioni.map(async (d) => ({
    ...d,
    rendered: await render(d),
  }))
);
---

<Layout 
  title="Testo Completo" 
  description="Il testo completo della Costituzione della Repubblica Italiana"
>
  <main class="py-8">
    <div class="max-w-6xl mx-auto px-4">
      <header class="text-center mb-12 pb-8 border-b-2 border-primary">
        <h1 class="text-4xl font-serif text-primary mb-2">Costituzione della Repubblica Italiana</h1>
        <p class="text-lg text-gray-500 mb-6">Testo completo</p>
        <button 
          class="no-print inline-flex items-center gap-2 px-4 py-2 bg-primary text-white rounded-lg font-medium hover:bg-primary-dark transition-colors" 
          onclick="window.print()"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6,9 6,2 18,2 18,9"/>
            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
            <rect x="6" y="14" width="12" height="8"/>
          </svg>
          Stampa
        </button>
      </header>

      <!-- Preamble -->
      <section class="max-w-3xl mx-auto mb-12 p-8 bg-gray-50 rounded-xl font-serif text-lg leading-relaxed text-center [data-theme='dark']:bg-gray-900">
        <p class="mb-4"><strong>IL CAPO PROVVISORIO DELLO STATO</strong></p>
        <p class="mb-4">
          Vista la deliberazione dell'Assemblea Costituente, che nella seduta 
          del 22 dicembre 1947 ha approvato la Costituzione della Repubblica Italiana;
        </p>
        <p class="mb-4">Vista la XVIII disposizione finale della Costituzione;</p>
        <p class="mb-4"><strong>PROMULGA</strong></p>
        <p class="m-0">la Costituzione della Repubblica Italiana nel seguente testo:</p>
      </section>

      <!-- Principî Fondamentali -->
      <section class="max-w-3xl mx-auto mb-12 print:break-before-page">
        <h2 id="principi-fondamentali" class="text-3xl font-serif text-primary text-center mb-8 pb-4 border-b border-gray-300 [data-theme='dark']:border-gray-700">
          Principî Fondamentali
        </h2>
        {renderedArticoli.filter(a => a.data.sezione === 'principi-fondamentali').map(({ data, rendered }) => (
          <article 
            class:list={['mb-6 pb-6 border-b border-gray-200 [data-theme="dark"]:border-gray-800', { 'opacity-60': data.abrogato }]} 
            id={`art-${data.numero}`}
          >
            <h3 class="text-base font-semibold text-primary mb-3">{data.titolo}</h3>
            <div class:list={['font-serif leading-relaxed prose prose-p:mb-3 prose-p:text-justify prose-ul:my-3 prose-ul:pl-6 max-w-none [data-theme="dark"]:prose-invert', { 'italic': data.abrogato }]}>
              <rendered.Content />
            </div>
          </article>
        ))}
      </section>

      <!-- Parte I -->
      <section class="max-w-3xl mx-auto mb-12 print:break-before-page">
        <h2 id="parte-1" class="text-3xl font-serif text-primary text-center mb-8 pb-4 border-b border-gray-300 [data-theme='dark']:border-gray-700">
          Parte I - Diritti e Doveri dei Cittadini
        </h2>
        
        {costituzioneStructure.parti[0].titoli.map((titolo) => (
          <div class="mb-10">
            <h3 id={`titolo-1-${titolo.numero.toLowerCase()}`} class="text-2xl font-serif mb-6 pb-2 border-b border-gray-200 [data-theme='dark']:border-gray-800">
              Titolo {titolo.numero} - {titolo.nome}
            </h3>
            {renderedArticoli.filter(a => a.data.parte === 'I' && a.data.titolo_sezione === titolo.numero).map(({ data, rendered }) => (
              <article 
                class:list={['mb-6 pb-6 border-b border-gray-200 [data-theme="dark"]:border-gray-800', { 'opacity-60': data.abrogato }]} 
                id={`art-${data.numero}`}
              >
                <h4 class="text-base font-semibold text-primary mb-3">{data.titolo}</h4>
                <div class:list={['font-serif leading-relaxed prose prose-p:mb-3 prose-p:text-justify prose-ul:my-3 prose-ul:pl-6 max-w-none [data-theme="dark"]:prose-invert', { 'italic': data.abrogato }]}>
                  <rendered.Content />
                </div>
              </article>
            ))}
          </div>
        ))}
      </section>

      <!-- Parte II -->
      <section class="max-w-3xl mx-auto mb-12 print:break-before-page">
        <h2 id="parte-2" class="text-3xl font-serif text-primary text-center mb-8 pb-4 border-b border-gray-300 [data-theme='dark']:border-gray-700">
          Parte II - Ordinamento della Repubblica
        </h2>
        
        {costituzioneStructure.parti[1].titoli.map((titolo) => (
          <div class="mb-10">
            <h3 id={`titolo-2-${titolo.numero.toLowerCase()}`} class="text-2xl font-serif mb-6 pb-2 border-b border-gray-200 [data-theme='dark']:border-gray-800">
              Titolo {titolo.numero} - {titolo.nome}
            </h3>
            
            {titolo.sezioni ? (
              titolo.sezioni.map((sezione) => (
                <div class="mb-8">
                  <h4 class="text-lg text-gray-600 mb-4 [data-theme='dark']:text-gray-400">
                    Sezione {sezione.id.split('-').pop()?.toUpperCase()} - {sezione.nome}
                  </h4>
                  {renderedArticoli.filter(a => sezione.articoli.includes(a.data.numero as number)).map(({ data, rendered }) => (
                    <article 
                      class:list={['mb-6 pb-6 border-b border-gray-200 [data-theme="dark"]:border-gray-800', { 'opacity-60': data.abrogato }]} 
                      id={`art-${data.numero}`}
                    >
                      <h5 class="text-base font-semibold text-primary mb-3">{data.titolo}</h5>
                      <div class:list={['font-serif leading-relaxed prose prose-p:mb-3 prose-p:text-justify prose-ul:my-3 prose-ul:pl-6 max-w-none [data-theme="dark"]:prose-invert', { 'italic': data.abrogato }]}>
                        <rendered.Content />
                      </div>
                    </article>
                  ))}
                </div>
              ))
            ) : (
              renderedArticoli.filter(a => a.data.parte === 'II' && a.data.titolo_sezione === titolo.numero).map(({ data, rendered }) => (
                <article 
                  class:list={['mb-6 pb-6 border-b border-gray-200 [data-theme="dark"]:border-gray-800', { 'opacity-60': data.abrogato }]} 
                  id={`art-${data.numero}`}
                >
                  <h4 class="text-base font-semibold text-primary mb-3">{data.titolo}</h4>
                  <div class:list={['font-serif leading-relaxed prose prose-p:mb-3 prose-p:text-justify prose-ul:my-3 prose-ul:pl-6 max-w-none [data-theme="dark"]:prose-invert', { 'italic': data.abrogato }]}>
                    <rendered.Content />
                  </div>
                </article>
              ))
            )}
          </div>
        ))}
      </section>

      <!-- Disposizioni Transitorie -->
      <section class="max-w-3xl mx-auto mb-12 print:break-before-page">
        <h2 id="disposizioni-transitorie" class="text-3xl font-serif text-primary text-center mb-8 pb-4 border-b border-gray-300 [data-theme='dark']:border-gray-700">
          Disposizioni Transitorie e Finali
        </h2>
        {renderedDisposizioni.map(({ data, rendered }) => (
          <article 
            class:list={['mb-6 pb-6 border-b border-gray-200 [data-theme="dark"]:border-gray-800', { 'opacity-60': data.abrogato }]} 
            id={`disp-${(data.numero as string).toLowerCase()}`}
          >
            <h3 class="text-base font-semibold text-primary mb-3">{data.numero}.</h3>
            <div class:list={['font-serif leading-relaxed prose prose-p:mb-3 prose-p:text-justify prose-ul:my-3 prose-ul:pl-6 max-w-none [data-theme="dark"]:prose-invert', { 'italic': data.abrogato }]}>
              <rendered.Content />
            </div>
          </article>
        ))}
      </section>

      <!-- Signatures -->
      <footer class="max-w-3xl mx-auto mt-12 pt-8 border-t-2 border-primary text-center font-serif text-lg">
        <p class="mb-4"><em>Data a Roma, addì 27 dicembre 1947.</em></p>
        <p class="mb-4"><em>Enrico De Nicola</em></p>
        <p class="mt-8 mb-4"><strong>CONTROFIRMANO:</strong></p>
        <p class="mb-4">Il Presidente dell'Assemblea Costituente<br><em>Umberto Terracini</em></p>
        <p class="mb-4">Il Presidente del Consiglio dei Ministri<br><em>Alcide De Gasperi</em></p>
        <p class="mb-4">Visto, il Guardasigilli:<br><em>Giuseppe Grassi</em></p>
      </footer>
    </div>
  </main>
</Layout>

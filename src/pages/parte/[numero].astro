---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import { costituzioneStructure } from '../../data/structure';

export function getStaticPaths() {
  return [
    { params: { numero: '1' } },
    { params: { numero: '2' } },
  ];
}

const { numero } = Astro.params;
const parteIndex = numero === '1' ? 0 : 1;
const parte = costituzioneStructure.parti[parteIndex];

const articoli = await getCollection('articoli', ({ data }) => 
  data.tipo === 'articolo' && data.parte === parte.numero
);

// Sort by article number
articoli.sort((a, b) => (a.data.numero as number) - (b.data.numero as number));

// Group by titolo
const articoliByTitolo = new Map<string, typeof articoli>();
for (const articolo of articoli) {
  const key = articolo.data.titolo_sezione || 'other';
  if (!articoliByTitolo.has(key)) {
    articoliByTitolo.set(key, []);
  }
  articoliByTitolo.get(key)!.push(articolo);
}
---

<Layout 
  title={`Parte ${parte.numero} - ${parte.nome}`} 
  description={`${parte.nome} - Costituzione della Repubblica Italiana`}
>
  <main class="section-page">
    <div class="container">
      <header class="section-header">
        <nav class="breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb-separator">/</span>
          <span>Parte {parte.numero}</span>
        </nav>
        <h1>Parte {parte.numero}</h1>
        <p class="section-title-main">{parte.nome}</p>
        <p class="section-description">
          Articoli {parte.titoli[0].articoli[0]} - {parte.titoli[parte.titoli.length - 1].articoli[parte.titoli[parte.titoli.length - 1].articoli.length - 1]}
        </p>
      </header>

      <div class="titoli-sections">
        {parte.titoli.map((titolo) => {
          const titoloArticoli = articoliByTitolo.get(titolo.numero) || [];
          return (
            <section class="titolo-section">
              <h2>Titolo {titolo.numero} - {titolo.nome}</h2>
              
              {titolo.sezioni ? (
                <div class="sezioni-list">
                  {titolo.sezioni.map((sezione) => {
                    const sezioneArticoli = titoloArticoli.filter(a => 
                      sezione.articoli.includes(a.data.numero as number)
                    );
                    return (
                      <div class="sezione-group">
                        <h3>Sezione {sezione.id.split('-').pop()?.toUpperCase()} - {sezione.nome}</h3>
                        <div class="articles-grid">
                          {sezioneArticoli.map((articolo) => (
                            <a 
                              href={`/articolo/${articolo.data.numero}`} 
                              class:list={['article-link', { abrogato: articolo.data.abrogato }]}
                            >
                              <span class="article-num">Art. {articolo.data.numero}</span>
                              {articolo.data.abrogato && <span class="badge-abrogato">abrogato</span>}
                            </a>
                          ))}
                        </div>
                      </div>
                    );
                  })}
                </div>
              ) : (
                <div class="articles-grid">
                  {titoloArticoli.map((articolo) => (
                    <a 
                      href={`/articolo/${articolo.data.numero}`} 
                      class:list={['article-link', { abrogato: articolo.data.abrogato }]}
                    >
                      <span class="article-num">Art. {articolo.data.numero}</span>
                      {articolo.data.abrogato && <span class="badge-abrogato">abrogato</span>}
                    </a>
                  ))}
                </div>
              )}
            </section>
          );
        })}
      </div>
    </div>
  </main>
</Layout>

<style>
  .section-page {
    padding: var(--space-8) 0;
  }

  .section-header {
    max-width: var(--max-width-content);
    margin: 0 auto var(--space-10);
    text-align: center;
  }

  .section-header h1 {
    margin-top: var(--space-4);
    margin-bottom: var(--space-2);
    color: var(--color-primary);
  }

  .section-title-main {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .section-description {
    color: var(--color-text-muted);
  }

  .titoli-sections {
    max-width: var(--max-width-content);
    margin: 0 auto;
  }

  .titolo-section {
    margin-bottom: var(--space-10);
    padding: var(--space-6);
    background-color: var(--color-bg-secondary);
    border-radius: var(--radius-lg);
  }

  .titolo-section h2 {
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border-light);
  }

  .sezioni-list {
    display: grid;
    gap: var(--space-6);
  }

  .sezione-group h3 {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .articles-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .article-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background-color: var(--color-bg-primary);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    transition: all var(--transition-fast);
  }

  .article-link:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    text-decoration: none;
  }

  .article-link.abrogato {
    opacity: 0.6;
  }

  .badge-abrogato {
    font-size: var(--text-xs);
    padding: 0 var(--space-1);
    background-color: var(--color-abrogato);
    color: white;
    border-radius: var(--radius-sm);
  }
</style>
